@model Admin.ViewModels.AdminAccount.EditAdminAccountViewModel
@{
    ViewData["Title"] = "編輯後台帳號";
}

<link rel="stylesheet" href="~/css/add-user.css" asp-append-version="true" />

<main class="main-content au-main">
    <div class="content-card">

        <nav class="au-breadcrumb">
            <a asp-action="Index" hx-get="@Url.Action("Index")" hx-target="#main-content" hx-push-url="true">後台帳號管理</a>
            <i class="fa-solid fa-chevron-right"></i>
            <span class="au-breadcrumb__current">編輯帳號</span>
        </nav>

        <div class="au-top-bar">
            <h1 class="au-page-title">編輯後台帳號</h1>
            <a asp-action="Index" class="au-back-btn" hx-get="@Url.Action("Index")" hx-target="#main-content"
               hx-push-url="true">
                <i class="fa-solid fa-arrow-left"></i> 返回列表
            </a>
        </div>

        <div asp-validation-summary="ModelOnly" class="au-validation-summary"></div>

        <div class="au-layout">
            <div class="au-form-panel">
                <form method="post" asp-action="Edit" asp-route-id="@Model.UserId"
                      hx-post="@Url.Action("Edit", new { id = Model.UserId })" hx-target="#main-content"
                      hx-swap="innerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />

                    <div class="au-form-body">
                        <div class="au-form-row">
                            <div class="au-form-group">
                                <label class="au-label" asp-for="Name">姓名</label>
                                <input type="text" asp-for="Name" class="au-input" placeholder="例如：王小明">
                                <span asp-validation-for="Name" class="au-validation-message"></span>
                            </div>
                            <div class="au-form-group">
                                <label class="au-label" asp-for="Email">電子郵件</label>
                                <input type="email" asp-for="Email" class="au-input" placeholder="admin@example.com">
                                <span asp-validation-for="Email" class="au-validation-message"></span>
                            </div>
                        </div>

                        <div class="au-form-row">
                            <div class="au-form-group">
                                <label class="au-label" asp-for="Department">部門</label>
                                <input type="text" asp-for="Department" class="au-input" placeholder="例如：營運部">
                                <span asp-validation-for="Department" class="au-validation-message"></span>
                            </div>
                            <div class="au-form-group">
                                <label class="au-label" asp-for="JobTitle">職稱</label>
                                <input type="text" asp-for="JobTitle" class="au-input" placeholder="例如：後台管理員">
                                <span asp-validation-for="JobTitle" class="au-validation-message"></span>
                            </div>
                        </div>

                        <div class="au-form-row">
                            <div class="au-form-group">
                                <label class="au-label" asp-for="Phone">聯絡電話</label>
                                <input type="text" asp-for="Phone" class="au-input" placeholder="例如：02-1234-5678">
                                <span asp-validation-for="Phone" class="au-validation-message"></span>
                            </div>
                        </div>

                        <div class="au-form-group">
                            <label class="au-label" asp-for="RoleIds">角色設定</label>
                            <div class="au-checkbox-list">
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    var isChecked = Model.RoleIds.Contains(long.Parse(role.Value!));
                                    <label class="au-checkbox-item">
                                        <input type="checkbox" name="RoleIds" value="@role.Value" checked="@isChecked" />
                                        <span>@role.Text</span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="RoleIds" class="au-validation-message"></span>
                        </div>

                        <div class="au-form-group">
                            <label class="au-label" asp-for="Note">備註</label>
                            <textarea asp-for="Note" class="au-input au-textarea" rows="3"
                                      placeholder="選填，輸入帳號相關備註..."></textarea>
                            <span asp-validation-for="Note" class="au-validation-message"></span>
                        </div>

                        <div class="au-form-footer">
                            <button type="submit" class="au-submit-btn">
                                <i class="fa-solid fa-floppy-disk"></i> 儲存變更
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="au-side-panels">
                <div class="au-info-panel">
                    <div class="au-info-panel__header">
                        <h2 class="au-info-panel__title">編輯提醒</h2>
                        <div class="au-info-panel__icon">
                            <i class="fa-regular fa-pen-to-square"></i>
                        </div>
                    </div>
                    <ol class="au-steps">
                        <li class="au-step">
                            <span class="au-step__num">01</span>
                            <p class="au-step__desc">變更電子郵件後，系統將驗證是否與其他帳號重複。</p>
                        </li>
                        <li class="au-step">
                            <span class="au-step__num">02</span>
                            <p class="au-step__desc">角色異動會立即生效，既有 Session 將於下次請求時重新載入權限。</p>
                        </li>
                        <li class="au-step">
                            <span class="au-step__num">03</span>
                            <p class="au-step__desc">所有編輯操作均會寫入異動紀錄。</p>
                        </li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
