@model Admin.ViewModels.AdminAccount.CreateAdminAccountViewModel
@{
    ViewData["Title"] = "新增後台帳號";
}

<link rel="stylesheet" href="~/css/add-user.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/manager.css" asp-append-version="true" />

<main class="main-content au-main">
    <div class="content-card">

        <nav class="au-breadcrumb">
            <a asp-action="Index" hx-get="@Url.Action("Index")" hx-target="#main-content" hx-push-url="true">後台帳號管理</a>
            <i class="fa-solid fa-chevron-right"></i>
            <span class="au-breadcrumb__current">新增帳號</span>
        </nav>

        <div class="au-top-bar">
            <h1 class="au-page-title">新增後台帳號</h1>
            <a asp-action="Index" class="au-back-btn" hx-get="@Url.Action("Index")" hx-target="#main-content"
               hx-push-url="true">
                <i class="fa-solid fa-arrow-left"></i> 返回列表
            </a>
        </div>

        <div asp-validation-summary="ModelOnly" class="au-validation-summary"></div>

        <div class="au-layout" style="grid-template-columns: 1fr;">
            <div class="au-form-panel">
                <form method="post" asp-action="Create" hx-post="@Url.Action("Create")" hx-target="#main-content"
                      hx-swap="innerHTML">
                    @Html.AntiForgeryToken()

                    <div class="au-form-body">
                        <div class="mgr-mf-section">基本資料</div>
                        <div class="mgr-mf-grid">
                            <div class="mgr-mf-field">
                                <label class="mgr-mf-label" asp-for="Name">姓名 <span
                                    class="mgr-mf-required">*</span></label>
                                    <input type="text" asp-for="Name" class="mgr-mf-input" placeholder="請輸入姓名">
                                    <span asp-validation-for="Name" class="au-validation-message"></span>
                                </div>
                                <div class="mgr-mf-field">
                                    <label class="mgr-mf-label" asp-for="Email">Email (帳號) <span
                                        class="mgr-mf-required">*</span></label>
                                        <input type="email" asp-for="Email" class="mgr-mf-input" placeholder="請輸入 Email">
                                        <span asp-validation-for="Email" class="au-validation-message"></span>
                                    </div>
                                    <div class="mgr-mf-field">
                                        <label class="mgr-mf-label" asp-for="Department">所屬部門</label>
                                        <input type="text" asp-for="Department" class="mgr-mf-input" placeholder="請輸入部門">
                                        <span asp-validation-for="Department" class="au-validation-message"></span>
                                    </div>
                                    <div class="mgr-mf-field">
                                        <label class="mgr-mf-label" asp-for="JobTitle">職稱</label>
                                        <input type="text" asp-for="JobTitle" class="mgr-mf-input" placeholder="請輸入職稱">
                                        <span asp-validation-for="JobTitle" class="au-validation-message"></span>
                                    </div>
                                    <div class="mgr-mf-field mgr-mf-field--full">
                                        <label class="mgr-mf-label" asp-for="Phone">聯絡電話</label>
                                        <input type="text" asp-for="Phone" class="mgr-mf-input" placeholder="請輸入聯絡電話">
                                        <span asp-validation-for="Phone" class="au-validation-message"></span>
                                    </div>
                                </div>

                                <div class="mgr-mf-section">角色設定 <span class="mgr-mf-required">*</span></div>
                                <div class="mgr-mf-roles">
                                    @foreach (var role in Model.AvailableRoles)
                                    {
                                        <label class="mgr-mf-role-item">
                                            <input type="checkbox" name="RoleIds" value="@role.Value" class="mgr-mf-checkbox" />
                                            <span>@role.Text</span>
                                        </label>
                                    }
                                </div>
                                <span asp-validation-for="RoleIds" class="au-validation-message"></span>

                                <div class="mgr-mf-section">備註</div>
                                <div class="mgr-mf-field mgr-mf-field--full">
                                    <textarea asp-for="Note" class="mgr-mf-textarea" rows="3"
                                              placeholder="請輸入關於此帳號的相關紀錄或備註..."></textarea>
                                    <span asp-validation-for="Note" class="au-validation-message"></span>
                                </div>

                                <div class="au-form-footer">
                                    <button type="submit" class="au-submit-btn">
                                        <i class="fa-solid fa-paper-plane"></i> 發送邀請
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="au-info-panel" style="margin-top: 1.6rem;">
                        <div class="au-info-panel__header">
                            <h2 class="au-info-panel__title">邀請說明</h2>
                            <div class="au-info-panel__icon">
                                <i class="fa-regular fa-envelope"></i>
                            </div>
                        </div>
                        <ol class="au-steps">
                            <li class="au-step">
                                <span class="au-step__num">01</span>
                                <p class="au-step__desc">受邀帳號將透過電子郵件收到<strong>帳號開通邀請函</strong>。</p>
                            </li>
                            <li class="au-step">
                                <span class="au-step__num">02</span>
                                <p class="au-step__desc">須在 <strong>48 小時內</strong>點擊連結完成<strong>密碼設定</strong>。</p>
                            </li>
                            <li class="au-step">
                                <span class="au-step__num">03</span>
                                <p class="au-step__desc">設定完成後即可依角色權限使用後台功能。</p>
                            </li>
                        </ol>
                        <div class="au-tip">
                            <p>提示：若帳號未收到信件，請確認電子郵件地址是否正確，或於帳號管理列表點擊「<strong>重發邀請</strong>」。</p>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        @section Scripts {
            <partial name="_ValidationScriptsPartial" />
            <script>
                (function () {
                    function refreshRoleStyles() {
                        document.querySelectorAll('.mgr-mf-roles .mgr-mf-checkbox').forEach(function (cb) {
                            cb.closest('.mgr-mf-role-item').classList.toggle('mgr-mf-role-item--checked', cb.checked);
                        });
                    }
                    var container = document.querySelector('.mgr-mf-roles');
                    if (container) {
                        container.addEventListener('change', refreshRoleStyles);
                        refreshRoleStyles();
                    }
                })();
            </script>
        }
