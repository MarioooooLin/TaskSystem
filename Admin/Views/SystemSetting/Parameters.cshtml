@model Admin.ViewModels.SystemSetting.SystemSettingParametersViewModel
@{
    ViewData["Title"] = "平台參數設定";
    var canManage = Model.CanManage;
}

@section PageCss {
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/platform-settings.css" asp-append-version="true" />
}

<main id="main-content" class="main-content ps-main">
    <div class="content-card">

        <nav class="st-breadcrumb">
            <a asp-action="Index" asp-controller="Dashboard">首頁</a>
            <span class="st-breadcrumb__sep">/</span>
            <a asp-action="Index">設定中心</a>
            <span class="st-breadcrumb__sep">/</span>
            <span class="st-breadcrumb__current">平台參數設定</span>
        </nav>

        <div class="st-page-header">
            <div class="page-header__left">
                <h1 class="st-page-title">平台參數設定</h1>
                <p class="st-page-desc">維護全平台商務參數，供案件建立、預算估算、導購分潤、KOL 提領與關帳規則使用。</p>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="ps-alert ps-alert--error">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="ps-alert ps-alert--error">
                @errorMessage
            </div>
        }

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="ps-alert ps-alert--success">
                @successMessage
            </div>
        }

        <form method="post" asp-action="Parameters" hx-post="/SystemSetting/Parameters" hx-target="#main-content" hx-swap="outerHTML">
            @Html.AntiForgeryToken()

            <!-- 全局提醒 -->
            <div class="ps-section">
                <h2 class="ps-section-title"><i class="fa-solid fa-circle-info"></i> 全局設定提醒</h2>
                <p class="ps-definition-desc">
                    以下參數為平台全局預設值，修改後只影響未來新建立的案件與使用者行為；已成立的訂單、案件任務與既有結算不會被回溯改寫。
                </p>
            </div>

            <!-- 核心商務參數 -->
            <div class="ps-section">
                <h2 class="ps-section-title"><i class="fa-solid fa-sliders"></i> 核心商務參數</h2>
                <div class="ps-form-grid">

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="CaseOpeningFeeAmount"><span class="required">*</span> 案件開案費（NT$）</label>
                        <input asp-for="CaseOpeningFeeAmount" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                        <span asp-validation-for="CaseOpeningFeeAmount" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="KolServiceFeeRate"><span class="required">*</span> KOL 服務費率（%）</label>
                        <div class="ps-input-wrap">
                            <input asp-for="KolServiceFeeRate" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                            <span class="ps-input-suffix">%</span>
                        </div>
                        <span asp-validation-for="KolServiceFeeRate" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="AffiliatePlatformCommissionRate"><span class="required">*</span> 平台抽成比例（%）</label>
                        <div class="ps-input-wrap">
                            <input asp-for="AffiliatePlatformCommissionRate" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                            <span class="ps-input-suffix">%</span>
                        </div>
                        <span asp-validation-for="AffiliatePlatformCommissionRate" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="AffiliateKolMinCommissionRate"><span class="required">*</span> KOL 最低分潤比例（%）</label>
                        <div class="ps-input-wrap">
                            <input asp-for="AffiliateKolMinCommissionRate" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                            <span class="ps-input-suffix">%</span>
                        </div>
                        <span asp-validation-for="AffiliateKolMinCommissionRate" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="CaseAutoExecutionThresholdRate"><span class="required">*</span> 案件自動執行門檻（%）</label>
                        <div class="ps-input-wrap">
                            <input asp-for="CaseAutoExecutionThresholdRate" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                            <span class="ps-input-suffix">%</span>
                        </div>
                        <span asp-validation-for="CaseAutoExecutionThresholdRate" class="ps-field-error"></span>
                        <p class="ps-field-hint">招募截止時，錄取人數達預計招募人數的此比例即可自動進入執行中。</p>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="KolMinPayoutAmount"><span class="required">*</span> 最低提領金額（NT$）</label>
                        <input asp-for="KolMinPayoutAmount" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                        <span asp-validation-for="KolMinPayoutAmount" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="KolTaxRate"><span class="required">*</span> KOL 稅金扣除率（%）</label>
                        <div class="ps-input-wrap">
                            <input asp-for="KolTaxRate" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                            <span class="ps-input-suffix">%</span>
                        </div>
                        <span asp-validation-for="KolTaxRate" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="KolPayoutFeeRate"><span class="required">*</span> KOL 提領手續費率（%）</label>
                        <div class="ps-input-wrap">
                            <input asp-for="KolPayoutFeeRate" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                            <span class="ps-input-suffix">%</span>
                        </div>
                        <span asp-validation-for="KolPayoutFeeRate" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="KolPayoutFixedFeeAmount"><span class="required">*</span> KOL 提領固定手續費（NT$）</label>
                        <input asp-for="KolPayoutFixedFeeAmount" type="number" step="0.01" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                        <span asp-validation-for="KolPayoutFixedFeeAmount" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="KolPayoutMode"><span class="required">*</span> 提領方式</label>
                        <input asp-for="KolPayoutMode" type="text" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                        <span asp-validation-for="KolPayoutMode" class="ps-field-error"></span>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="KolPayoutDays"><span class="required">*</span> 撥款日</label>
                        <input asp-for="KolPayoutDays" type="text" class="ps-input" placeholder="例如：10,25" disabled="@(canManage ? null : "disabled")" />
                        <span asp-validation-for="KolPayoutDays" class="ps-field-error"></span>
                        <p class="ps-field-hint">多個日期請以逗號分隔，例如 10,25。</p>
                    </div>

                    <div class="ps-form-field">
                        <label class="ps-form-label" asp-for="KolPayoutClosingDayOffset"><span class="required">*</span> 關帳日設定（撥款日前 N 日）</label>
                        <input asp-for="KolPayoutClosingDayOffset" type="number" class="ps-input" disabled="@(canManage ? null : "disabled")" />
                        <span asp-validation-for="KolPayoutClosingDayOffset" class="ps-field-error"></span>
                        <p class="ps-field-hint">請輸入負數，例如 -5 表示撥款日前 5 日關帳。</p>
                    </div>

                    <div class="ps-form-field ps-form-field--full">
                        <label class="ps-form-label" asp-for="Note">異動備註</label>
                        <textarea asp-for="Note" class="ps-textarea" disabled="@(canManage ? null : "disabled")" placeholder="記錄此次異動原因，便於後續稽核追蹤"></textarea>
                        <span asp-validation-for="Note" class="ps-field-error"></span>
                    </div>

                </div>
            </div>

            <!-- 名詞與業務定義 -->
            <div class="ps-section">
                <h2 class="ps-section-title"><i class="fa-solid fa-book-open"></i> 名詞與業務定義</h2>
                <div class="ps-definition-list">
                    <div class="ps-definition-item">
                        <span class="ps-definition-term">現金酬勞</span>
                        <span class="ps-definition-desc">業者直接支付給 KOL 的固定現金報酬，不包含後續導購抽成。</span>
                    </div>
                    <div class="ps-definition-item">
                        <span class="ps-definition-term">體驗項目</span>
                        <span class="ps-definition-desc">業者提供的商品或服務，作為實物報酬，平台不對體驗項目的價值進行抽成，僅收取開案費。</span>
                    </div>
                    <div class="ps-definition-item">
                        <span class="ps-definition-term">導購分潤</span>
                        <span class="ps-definition-desc">透過專屬連結產生的訂單金額，依據設定比例分配給 KOL 與平台。</span>
                    </div>
                </div>
            </div>

            @if (canManage)
            {
                <div class="ps-actions">
                    <button type="button"
                            class="st-btn st-btn--outline"
                            hx-post="/SystemSetting/Reset" hx-target="#main-content" hx-swap="outerHTML"
                            hx-confirm="確定要將所有參數還原為預設值嗎？">
                        <i class="fa-solid fa-rotate-left"></i> 還原預設
                    </button>
                    <button type="submit" class="st-btn st-btn--primary">
                        <i class="fa-solid fa-floppy-disk"></i> 儲存設定
                    </button>
                </div>
            }
        </form>

        <!-- 近期異動紀錄 -->
        <div class="ps-section">
            <h2 class="ps-section-title"><i class="fa-solid fa-clock-rotate-left"></i> 近期異動紀錄 <span class="ps-section-count">（最近 @Model.RecentLogs.Count 筆）</span></h2>
            @if (Model.RecentLogs.Count == 0)
            {
                <p class="ps-log-empty">目前尚無異動紀錄。</p>
            }
            else
            {
                <div class="ps-log-scroll">
                    <table class="ps-log-table">
                        <thead>
                            <tr>
                                <th>異動時間</th>
                                <th>操作人員</th>
                                <th>異動項目</th>
                                <th>原設定值</th>
                                <th>新設定值</th>
                                <th>備註</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.RecentLogs)
                            {
                                <tr>
                                    <td>@log.ChangedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@log.ChangedByName</td>
                                    <td>@log.SettingName</td>
                                    <td>@log.OldValue</td>
                                    <td>@log.NewValue</td>
                                    <td>@log.Note</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
