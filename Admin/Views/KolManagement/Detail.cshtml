@model Application.Kols.DTOs.KolDetailDto
@using Domain.Enums
@{
    ViewData["Title"] = "KOL詳細檔案";

    var isSuspended = Model.VerificationStatus == VerificationStatus.Suspended;
    var isApproved = Model.VerificationStatus == VerificationStatus.Approved;
    var isPending = Model.VerificationStatus == VerificationStatus.Pending;
    var isRejected = Model.VerificationStatus == VerificationStatus.Rejected;

    var (statusCss, statusText) = Model.VerificationStatus switch
    {
        VerificationStatus.Approved => ("kd-badge--active", "啟用中"),
        VerificationStatus.Pending => ("kd-badge--pending", "待審核"),
        VerificationStatus.Rejected => ("kd-badge--reject", "已退回"),
        VerificationStatus.Suspended => ("kd-badge--suspend", "已停權"),
        _ => ("", "未知"),
    };

    // 主要平台：取粉絲數最多的前 3 平台
    string PlatformLabel(short p) => p switch
    {
        1 => "X",
        2 => "Instagram",
        3 => "Facebook",
        4 => "YouTube",
        5 => "Blog",
        6 => "小紅書",
        7 => "TikTok",
        8 => "中國抖音",
        9 => "Threads",
        10 => "Snapchat",
        11 => "微信",
        _ => "其他"
    };

    string PlatformIcon(short p) => p switch
    {
        1 => "fa-brands fa-x-twitter",
        2 => "fa-brands fa-instagram",
        3 => "fa-brands fa-facebook",
        4 => "fa-brands fa-youtube",
        5 => "fa-solid fa-rss",
        6 => "fa-solid fa-circle-dot",
        7 => "fa-brands fa-tiktok",
        8 => "fa-brands fa-tiktok",
        9 => "fa-brands fa-threads",
        10 => "fa-brands fa-snapchat",
        11 => "fa-brands fa-weixin",
        _ => "fa-solid fa-share-nodes"
    };

    string CategoryLabel(short c) => c switch
    {
        1 => "旅遊",
        2 => "旅行",
        3 => "時尚",
        4 => "美妝",
        5 => "居家生活",
        6 => "親子",
        7 => "寵物",
        8 => "遊戲",
        9 => "音樂",
        10 => "影視",
        11 => "藝術",
        12 => "書籍",
        13 => "科技",
        14 => "財經",
        15 => "教育",
        16 => "職場",
        17 => "健康",
        18 => "健身",
        19 => "運動",
        20 => "飲食",
        21 => "養生",
        22 => "公益",
        23 => "環保",
        24 => "政治",
        25 => "文化",
        26 => "跨界",
        _ => "其他"
    };

    string DataSourceLabel(short ds) => ds switch { 1 => "API（同步）", 2 => "手動輸入", _ => "未知" };

    string BankAccountTypeLabel(short t) => t switch { 1 => "個人", 2 => "公司", _ => "其他" };

    string BankStatusLabel(short s) => s switch { 1 => "待確認", 2 => "已審核", 3 => "已退回", _ => "未知" };

    string TaskStatusLabel(short s) => s switch
    {
        1 => "待媒合",
        2 => "待執行",
        3 => "執行中",
        4 => "驗收中",
        5 => "修改中",
        6 => "已完成",
        7 => "未完成",
        8 => "已取消",
        _ => "未知"
    };

    string TaskStatusCss(short s) => s switch
    {
        3 => "kd-badge--running",
        6 => "kd-badge--paid",
        7 => "kd-badge--reject",
        8 => "kd-badge--reject",
        _ => "kd-badge--pending"
    };

    var mainPlatformText = string.Join(" / ",
        Model.SocialAccounts
             .OrderByDescending(s => s.FollowersCount ?? 0)
             .Take(3)
             .Select(s => PlatformLabel(s.Platform)));

    var bankBadgeCss = Model.BankAccount is null ? "kd-badge--pending"
                      : Model.BankAccount.Status == 2 ? "kd-badge--bound" : "kd-badge--pending";
    var bankBadgeText = Model.BankAccount is null ? "未綁定"
                      : Model.BankAccount.Status == 2 ? "已綁定" : "待確認";
}

<link rel="stylesheet" href="~/css/kol-detail.css" asp-append-version="true" />

@if (TempData["Success"] is string successMsg)
{
    <div class="alert-success">@successMsg</div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="alert-error">@errorMsg</div>
}

<!-- ===== PAGE HEADER ===== -->
<div class="page-header kd-page-header">
    <div class="page-header__left">
        <nav class="adm-breadcrumb">首頁 &rsaquo; KOL管理 &rsaquo; 詳細檔案</nav>
        <h1 class="page-title">KOL詳細檔案</h1>
        <p class="page-subtitle">查看KOL資料、社群頻道、審核狀態、任務紀錄、收款與異常紀錄</p>
    </div>
    <div class="kd-header-actions">
        <button class="kd-btn kd-btn--outline" disabled title="代理登入功能開發中"><i class="fa-solid fa-arrow-right-to-bracket"></i> 代理登入</button>
        <a asp-action="Index" class="kd-btn kd-btn--ghost"
           hx-get="@Url.Action("Index")" hx-target="#main-content" hx-push-url="true">
            返回KOL管理
        </a>
    </div>
</div>

<!-- ===== SUMMARY ===== -->
<div class="content-card kd-summary-card">
    <div class="kd-summary-left">
        <div class="kd-summary-icon">
            <img src="~/images/user.svg" alt="KOL頭貼" class="kd-summary-avatar" />
        </div>
        <div class="kd-summary-meta">
            <h2 class="kd-kol-name">@Model.DisplayName</h2>
            <span class="kd-badge @statusCss"><i class="fa-solid fa-circle"></i> @statusText</span>
        </div>
    </div>
    <div class="kd-summary-info-grid">
        <div class="kd-summary-info-item">
            <span class="kd-summary-label">KOL類型</span>
            <div class="kd-chip-group">
                @if (Model.Categories.Any())
                {
                    @foreach (var cat in Model.Categories)
                    {
                        <span class="kd-chip">@CategoryLabel(cat)</span>
                    }
                }
                else
                {
                    <span class="kd-summary-value">—</span>
                }
            </div>
        </div>
        <div class="kd-summary-info-item">
            <span class="kd-summary-label">主要平台</span>
            <span class="kd-summary-value">@(string.IsNullOrEmpty(mainPlatformText) ? "—" : mainPlatformText)</span>
        </div>
        <div class="kd-summary-info-item">
            <span class="kd-summary-label">粉絲總數</span>
            <span class="kd-summary-value kd-summary-value--strong">@Model.TotalFollowers.ToString("N0")</span>
        </div>
        <div class="kd-summary-info-item">
            <span class="kd-summary-label">收款資料狀態</span>
            <span class="kd-badge @bankBadgeCss">@bankBadgeText</span>
        </div>
        <div class="kd-summary-info-item">
            <span class="kd-summary-label">任務數</span>
            <span class="kd-summary-value">@Model.TaskCount</span>
        </div>
        <div class="kd-summary-info-item">
            <span class="kd-summary-label">驗收通過數</span>
            <span class="kd-summary-value">@Model.CompletedTaskCount</span>
        </div>
        <div class="kd-summary-info-item">
            <span class="kd-summary-label">未結案異議數</span>
            <span
            class="kd-summary-value @(Model.DisputeCount > 0 ? "kd-summary-value--danger" : "")">@Model.DisputeCount</span>
        </div>
        <div class="kd-summary-info-item">
            <span class="kd-summary-label">放棄任務次數</span>
            <span class="kd-summary-value">@Model.AbandonedTaskCount</span>
        </div>
    </div>
</div>

<!-- ===== 基本資料 ===== -->
<div class="content-card">
    <h2 class="section-title kd-section-title"><i class="fa-regular fa-user"></i> 基本資料</h2>
    <div class="kd-card-grid kd-card-grid--2">

        <section class="kd-info-card">
            <h3 class="kd-card-title">KOL個人資料</h3>
            <div class="kd-kv-list">
                <div class="kd-kv-row"><span>KOL名稱</span><strong>@Model.DisplayName</strong></div>
                @if (!string.IsNullOrEmpty(Model.RealName))
                {
                    <div class="kd-kv-row"><span>真實姓名</span><strong>@Model.RealName</strong></div>
                }
                <div class="kd-kv-row"><span>手機</span><strong>@(Model.Phone ?? "—")</strong></div>
                <div class="kd-kv-row"><span>Email</span><strong>@Model.UserEmail</strong></div>
                <div class="kd-kv-row">
                    <span>LINE綁定狀態</span>
                    @if (!string.IsNullOrEmpty(Model.LineContactId))
                    {
                        <strong class="kd-kv-success"><i class="fa-solid fa-circle-check"></i> 已綁定</strong>
                    }
                    else
                    {
                        <strong>未綁定</strong>
                    }
                </div>
                <div class="kd-kv-row"><span>建立日期</span><strong>@Model.CreatedAt.ToString("yyyy-MM-dd")</strong></div>
            </div>
        </section>

        <section class="kd-info-card">
            <h3 class="kd-card-title">KOL定位</h3>
            <div class="kd-kv-list">
                <div class="kd-kv-row kd-kv-row--stack">
                    <span>KOL類型</span>
                    <div class="kd-chip-group">
                        @if (Model.Categories.Any())
                        {
                            @foreach (var cat in Model.Categories)
                            {
                                <span class="kd-chip">@CategoryLabel(cat)</span>
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Intro))
                {
                    <div class="kd-kv-row kd-kv-row--stack">
                        <span>自我介紹</span>
                        <p class="kd-intro">@Model.Intro</p>
                    </div>
                }
                <div class="kd-kv-row kd-kv-row--stack">
                    <span>可合作條件</span>
                    <p class="kd-conditions">
                        @if (Model.AcceptsCash)
                        {
                            <text>✓ 現金酬勞　</text>
                        }
                        @if (Model.AcceptsBarter)
                        {
                            <text>✓ 贈品項目　</text>
                        }
                        @if (Model.AcceptsCommission)
                        {
                            <text>✓ 導購分潤</text>
                        }
                        @if (!Model.AcceptsCash && !Model.AcceptsBarter && !Model.AcceptsCommission)
                        {
                            <text>—</text>
                        }
                    </p>
                </div>
            </div>
        </section>

    </div>
</div>

<!-- ===== 社群頻道 ===== -->
<div class="content-card">
    <h2 class="section-title kd-section-title"><i class="fa-solid fa-share-nodes"></i> 社群頻道</h2>
    <div class="table-section">
        <table class="data-table kd-table">
            <thead>
                <tr>
                    <th>平台</th>
                    <th>帳號名稱</th>
                    <th>粉絲數</th>
                    <th>資料來源</th>
                    <th>最後更新</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.SocialAccounts.Any())
                {
                    @foreach (var sa in Model.SocialAccounts)
                    {
                        <tr>
                            <td><i class="@PlatformIcon(sa.Platform) kd-platform-icon"></i> @PlatformLabel(sa.Platform)</td>
                            <td>@sa.AccountName</td>
                            <td>@(sa.FollowersCount.HasValue ? sa.FollowersCount.Value.ToString("N0") : "—")</td>
                            <td>@DataSourceLabel(sa.DataSource)</td>
                            <td>@(sa.LastSyncAt.HasValue? sa.LastSyncAt.Value.ToString("yyyy-MM-dd") :
                        sa.UpdatedAt.ToString("yyyy-MM-dd"))</td>
                            </tr>
                        }
                    }
                else
                    {
                        <tr>
                            <td colspan="5" class="empty-state">尚未綁定社群帳號</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ===== 收款資料 ===== -->
    <div class="content-card">
        <h2 class="section-title kd-section-title"><i class="fa-solid fa-building-columns"></i> 收款資料</h2>
        @if (Model.BankAccount is not null)
        {
            <div class="kd-card-grid kd-card-grid--payment">
                <section class="kd-info-card">
                    <div class="kd-kv-list kd-kv-list--payment">
                        <div class="kd-kv-row">
                            <span>收款身份</span><strong>@BankAccountTypeLabel(Model.BankAccount.AccountType)</strong></div>
                            <div class="kd-kv-row"><span>收款戶名</span><strong>@Model.BankAccount.AccountName</strong></div>
                            <div class="kd-kv-row">
                                <span>銀行</span>
                                <strong>@Model.BankAccount.BankCode@(Model.BankAccount.BankName is not null ? $"   {Model.BankAccount.BankName}" : "")</strong>
                            </div>
                            <div class="kd-kv-row"><span>銀行帳號</span><strong>@Model.BankAccount.MaskedAccountNumber</strong></div>
                            <div class="kd-kv-row"><span>收款資料狀態</span><strong
                                class="kd-kv-success">@BankStatusLabel(Model.BankAccount.Status)</strong></div>
                                <div class="kd-kv-row"><span>最近更新</span><strong>@Model.BankAccount.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</strong></div>
                            </div>
                        </section>
                        <aside class="kd-payment-hint">
                            <h3><i class="fa-regular fa-shield-check"></i> 隱私與安全</h3>
                            <p>收款資料僅供查核，不顯示完整敏感資訊。</p>
                        </aside>
                    </div>
                }
    else
                {
                    <p class="empty-state">KOL 尚未填寫收款資料。</p>
                }
            </div>

            <!-- ===== KOL管理 ===== -->
            <div class="content-card">
                <h2 class="section-title kd-section-title"><i class="fa-solid fa-screwdriver-wrench"></i> KOL管理</h2>

                @* 審核操作：待審核或已退回 *@
                @if (isPending || isRejected)
                {
                    <div class="kd-management-box">
                        <label class="kd-management-label">審核操作</label>
                        <form method="post" asp-action="Approve" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.KolId" />
                            <button type="submit" class="kd-btn kd-btn--primary">通過審核</button>
                        </form>
                    </div>
                    @if (isPending)
                    {
                        <form method="post" asp-action="Reject" style="margin-top:12px">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="KolId" value="@Model.KolId" />
                            <div class="kd-management-box">
                                <label class="kd-management-label">退回修改</label>
                                <textarea class="kd-management-textarea" name="RejectionNote" rows="3" placeholder="請輸入退回原因（必填）..."
                                          aria-label="退回原因"></textarea>
                                <div class="kd-management-actions">
                                    <button type="submit" class="kd-btn kd-btn--danger">退回修改</button>
                                </div>
                            </div>
                        </form>
                    }
                }

                @* 停權操作：啟用中 *@
                @if (isApproved)
                {
                    <form method="post" asp-action="Suspend">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="KolId" value="@Model.KolId" />
                        <div class="kd-management-box">
                            <label class="kd-management-label">KOL管理操作</label>
                            <textarea class="kd-management-textarea" name="SuspensionNote" rows="3" placeholder="請輸入停權原因（必填）..."
                                      aria-label="停權原因"></textarea>
                            <div class="kd-management-actions">
                                <button type="submit" class="kd-btn kd-btn--danger"
                                        onclick="return confirm('確定要停權此 KOL 嗎？')">停權</button>
                            </div>
                        </div>
                    </form>
                }

                @* 解除停權：已停權 *@
                @if (isSuspended)
                {
                    <div class="kd-management-box">
                        <label class="kd-management-label">KOL管理操作</label>
                        @if (!string.IsNullOrEmpty(Model.SuspensionNote))
                        {
                            <p class="kd-intro">停權原因：@Model.SuspensionNote</p>
                        }
                        <div class="kd-management-actions">
                            <form method="post" asp-action="Unsuspend" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.KolId" />
                                <button type="submit" class="kd-btn kd-btn--danger-outline"
                                        onclick="return confirm('確定要解除此 KOL 的停權嗎？')">解除停權</button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <!-- ===== 任務與異議追蹤 ===== -->
            <div class="content-card">
                <h2 class="section-title kd-section-title"><i class="fa-solid fa-list-check"></i> 任務與異議追蹤</h2>
                <div class="table-section">
                    <table class="data-table kd-table">
                        <thead>
                            <tr>
                                <th>狀態</th>
                                <th>案件名稱</th>
                                <th>合作條件</th>
                                <th>備註</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentTasks.Any())
                            {
                                @foreach (var task in Model.RecentTasks)
                                {
                                    <tr>
                                        <td><span class="kd-badge @TaskStatusCss(task.TaskStatus)">@TaskStatusLabel(task.TaskStatus)</span>
                                        </td>
                                        <td>@task.CaseTitle</td>
                                        <td>NT$@task.CashRewardAmount.ToString("N0")</td>
                                        <td>—</td>
                                        <td>
                                            <a asp-controller="CaseMonitor" asp-action="Detail" asp-route-id="@task.CaseId"
                                               class="action-link"
                                               hx-get="@Url.Action("Detail", "CaseMonitor", new { id = task.CaseId })"
                                               hx-target="#main-content" hx-push-url="true">查看案件</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="empty-state">尚無任務紀錄</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.RecentTasks.Any())
                {
                    <div class="kd-table-footer pagination">
                        <span class="pagination__info">共 @Model.RecentTasks.Count 筆紀錄（最新 10 筆）</span>
                    </div>
                }
            </div>

            <!-- ===== 收益摘要 ===== -->
            <div class="content-card">
                <h2 class="section-title kd-section-title"><i class="fa-solid fa-wallet"></i> 收益摘要</h2>
                <div class="kd-income-grid">
                    <div class="kd-income-item">
                        <span>待月結</span>
                        <strong>NT$@Model.Earnings.PendingAmount.ToString("N0")</strong>
                    </div>
                    <div class="kd-income-item">
                        <span>待匯款</span>
                        <strong>NT$@Model.Earnings.RequestedAmount.ToString("N0")</strong>
                    </div>
                    <div class="kd-income-item">
                        <span>已匯款</span>
                        <strong>NT$@Model.Earnings.PaidAmount.ToString("N0")</strong>
                    </div>
                    <div class="kd-income-item">
                        <span>可請款餘額</span>
                        <strong>NT$@Model.Earnings.AvailableAmount.ToString("N0")</strong>
                    </div>
                </div>
            </div>

            <!-- ===== 操作紀錄 ===== -->
            <div class="content-card">
                <h2 class="section-title kd-section-title"><i class="fa-solid fa-clock"></i> 操作紀錄</h2>
                @if (Model.RecentActivityLogs.Any())
                {
                    @foreach (var log in Model.RecentActivityLogs)
                    {
                        <div class="kd-log-item">
                            <strong>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</strong>
                            <span><mark>@log.Action</mark>@(string.IsNullOrEmpty(log.Note) ? "" : $" {log.Note}")</span>
                            @if (!string.IsNullOrEmpty(log.ActorName))
                            {
                                <span class="kd-log-user">@log.ActorName</span>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="empty-state">尚無操作紀錄</p>
                }
            </div>
