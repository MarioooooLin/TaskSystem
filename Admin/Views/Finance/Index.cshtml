@model Admin.ViewModels.Finance.FinanceIndexViewModel
@using Domain.Enums
@{
    ViewData["Title"] = "帳務總覽";
    var q = Model.Query;
    var keyword = q.Keyword ?? "";
    var statusVal = q.Status.HasValue ? ((int)q.Status.Value).ToString() : "";
    var dateFrom = q.DateFrom?.ToString("yyyy-MM-dd") ?? "";
    var dateTo = q.DateTo?.ToString("yyyy-MM-dd") ?? "";
    var list = Model.List;
    var summary = Model.Summary;
    var actionUrl = Url.Action("Index")!;
}

<link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />

<!-- ===== PAGE HEADER ===== -->
<div class="page-header acc-page-header">
    <div class="page-header__left">
        <h1 class="page-title">綜合財務監控面板</h1>
        <p class="page-subtitle">全面追蹤案件資金收入、支出與結算狀態。</p>
    </div>
    @* TODO: 匯出報表功能第一版暫緩實作 *@
    <button type="button" class="btn-primary" disabled title="匯出報表功能暫緩實作">
        <i class="fa-solid fa-file-arrow-down"></i> 匯出報表
    </button>
</div>

<!-- ===== KPI SUMMARY ===== -->
<div class="acc-kpi-row">
    <div class="content-card acc-kpi-card">
        <div class="acc-kpi-card__header">
            <span class="acc-kpi-card__label">平台總收入</span>
            <span class="acc-kpi-card__icon acc-kpi-card__icon--income">
                <i class="fa-solid fa-circle-dollar-to-slot"></i>
            </span>
        </div>
        <strong class="acc-kpi-card__amount">NT$ @summary.TotalIncome.ToString("N0")</strong>
        <span class="acc-kpi-card__sub">總資金收入（業者）</span>
    </div>
    <div class="content-card acc-kpi-card">
        <div class="acc-kpi-card__header">
            <span class="acc-kpi-card__label">平台總支出</span>
            <span class="acc-kpi-card__icon acc-kpi-card__icon--expense">
                <i class="fa-solid fa-calculator"></i>
            </span>
        </div>
        <strong class="acc-kpi-card__amount">NT$ @summary.TotalExpense.ToString("N0")</strong>
        <span class="acc-kpi-card__sub">總資金支出（KOL）</span>
    </div>
    <div class="content-card acc-kpi-card">
        <div class="acc-kpi-card__header">
            <span class="acc-kpi-card__label">平台毛利</span>
            <span class="acc-kpi-card__icon acc-kpi-card__icon--profit">
                <i class="fa-solid fa-cash-register"></i>
            </span>
        </div>
        <strong class="acc-kpi-card__amount">NT$ @summary.GrossProfit.ToString("N0")</strong>
        <span class="acc-kpi-card__sub">平台淨利潤</span>
    </div>
</div>

<!-- ===== FILTER ===== -->
<form id="finance-filter-form" method="get" asp-action="Index" hx-get="@actionUrl" hx-target="#finance-results"
      hx-select="#finance-results" hx-swap="outerHTML" hx-push-url="true">
    <input type="hidden" id="finance-status-input" name="status" value="@statusVal" />

    <div class="content-card acc-filter">
        <div class="acc-filter-row">
            <div class="acc-filter-item acc-filter-item--grow">
                <label class="acc-filter-label">關鍵字</label>
                <div class="filter-search">
                    <i class="fa-solid fa-magnifying-glass filter-search__icon"></i>
                    <input type="text" name="keyword" value="@keyword" class="filter-search__input"
                           placeholder="搜尋案件編號、業者名稱...">
                </div>
            </div>
            <div class="acc-filter-item">
                <label class="acc-filter-label">監控時間範圍</label>
                <div class="acc-filter-daterange">
                    <input type="date" name="dateFrom" value="@dateFrom" class="acc-date-input" aria-label="開始日期">
                    <span class="acc-date-sep">至</span>
                    <input type="date" name="dateTo" value="@dateTo" class="acc-date-input" aria-label="結束日期">
                </div>
            </div>
            <div class="acc-filter-item">
                <label class="acc-filter-label">狀態</label>
                <div class="filter-select-wrap">
                    <select name="statusSelect" class="filter-select" id="finance-status-select">
                        <option value="" selected="@(string.IsNullOrEmpty(statusVal) ? "selected" : null)">全部 (All)
                        </option>
                        <option value="4" selected="@(statusVal == "4" ? "selected" : null)">執行中</option>
                        <option value="6" selected="@(statusVal == "6" ? "selected" : null)">已結案</option>
                        <option value="5" selected="@(statusVal == "5" ? "selected" : null)">已完成</option>
                    </select>
                    <i class="fa-solid fa-chevron-down filter-select__arrow"></i>
                </div>
            </div>
            <button type="submit" class="btn-primary acc-filter-btn">套用篩選</button>
        </div>
    </div>
</form>

<!-- ===== MAIN TABLE ===== -->
<div id="finance-results" class="content-card">
    <div class="table-section table-section--scrollable table-section--scrollable-y">
        <table class="data-table acc-table">
            <thead>
                <tr>
                    <th class="acc-th-toggle"></th>
                    <th>建立日期</th>
                    <th>業者名稱</th>
                    <th>案件名稱</th>
                    <th>收入金額（業者）</th>
                    <th>支出金額（KOL）</th>
                    <th>狀態</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in list.Items)
                {
                    var (statusCss, statusText) = item.Status switch
                    {
                        CaseStatus.Draft => ("acc-status acc-status--running", "草稿"),
                        CaseStatus.Recruiting => ("acc-status acc-status--running", "招募中"),
                        CaseStatus.RecruitmentClosed => ("acc-status acc-status--running", "招募截止"),
                        CaseStatus.InProgress => ("acc-status acc-status--running", "執行中"),
                        CaseStatus.Completed => ("acc-status acc-status--closed", "已完成"),
                        CaseStatus.Settled => ("acc-status acc-status--closed", "已結案"),
                        CaseStatus.Cancelled => ("acc-status acc-status--closed", "已取消"),
                        _ => ("acc-status", "—"),
                    };

                    // 如果案件有未結案異議，優先顯示爭議中樣式
                    if (item.HasOpenDispute)
                    {
                        statusCss = "acc-status acc-status--dispute";
                        statusText = "爭議中";
                    }

                    var detailId = $"finance-detail-{item.CaseId}";
                    // TODO: 收入明細 breakdown 目前 Model 無法提供，待財務公式與欄位到位後補齊

                    <tr class="acc-main-row" id="finance-row-@item.CaseId" data-row="@item.CaseId">
                        <td class="acc-td-toggle">
                            <button type="button" class="acc-toggle-btn">
                                <i class="fa-solid fa-chevron-right"></i>
                            </button>
                        </td>
                        <td class="acc-td-date">@(item.SettledAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td class="acc-td-biz">@item.MerchantName</td>
                        <td class="acc-td-case">
                            <strong>@item.Title</strong>
                            <span>@item.CaseNo</span>
                        </td>
                        <td class="acc-td-income">
                            <strong class="acc-income-total">NT$ @item.IncomeAmount.ToString("N0")</strong>
                            @* TODO: 收入 breakdown（管理佣金 / 門票費用 / KOL委任佣金 / 折扣退款）待 Model 補齊 *@
                            <ul class="acc-income-breakdown">
                                <li><span>管理佣金</span><span>—</span></li>
                                <li><span>門票費用</span><span>—</span></li>
                                <li><span>KOL 委任佣金</span><span>—</span></li>
                                <li><span>折扣 / 退款</span><span>—</span></li>
                            </ul>
                        </td>
                        <td class="acc-td-expense">NT$ @item.ExpenseAmount.ToString("N0")</td>
                        <td><span class="@statusCss">@statusText</span></td>
                        <td class="ob-actions">
                            <a asp-controller="CaseMonitor" asp-action="Detail" asp-route-id="@item.CaseId"
                               class="action-link" hx-get="/CaseMonitor/Detail/@item.CaseId" hx-target="#main-content"
                               hx-push-url="true">案件詳情</a>
                        </td>
                    </tr>
                    <tr class="acc-sub-row acc-sub-row--hidden" id="@detailId" data-parent="@item.CaseId">
                        <td colspan="8" class="acc-sub-cell">
                            <div class="acc-subtable-wrap">
                                <p class="acc-subtable-title"><i class="fa-solid fa-list-check"></i> 任務明細</p>
                                <table class="acc-subtable">
                                    <thead>
                                        <tr>
                                            <th>KOL 姓名</th>
                                            <th>任務稿酬 (MISSION)</th>
                                            <th>導購佣金 (AFFILIATE)</th>
                                            <th>稅金/手續費</th>
                                            <th>淨付金額</th>
                                            <th>狀態</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in item.TaskDetails)
                                        {
                                            var subStatusCss = d.StatusText switch
                                            {
                                                "已付款" => "acc-sub-status--paid",
                                                "待付款" => "acc-sub-status--pending",
                                                _ => "acc-sub-status--dispute"
                                            };
                                            <tr>
                                                <td>@d.KolName</td>
                                                <td>NT$ @d.MissionAmount.ToString("N0")</td>
                                                <td>NT$ @d.AffiliateAmount.ToString("N0")</td>
                                                <td>NT$ @d.TaxFeeAmount.ToString("N0")</td>
                                                <td><strong>NT$ @d.NetAmount.ToString("N0")</strong></td>
                                                <td><span class="acc-sub-status @subStatusCss">@d.StatusText</span></td>
                                            </tr>
                                        }
                                        @if (!item.TaskDetails.Any())
                                        {
                                            <tr>
                                                <td colspan="6" class="empty-state">暫無 KOL 任務帳務明細。</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </td>
                    </tr>
                }
                @if (!list.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="empty-state">查無符合條件的帳務資料。</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ===== PAGINATION ===== -->
    @if (list.TotalPages >= 1)
    {
        var startItem = (list.Page - 1) * list.PageSize + 1;
        var endItem = Math.Min(list.Page * list.PageSize, list.TotalCount);
        <div class="pagination">
            <span class="pagination__info">
                顯示第 @startItem 到 @endItem 筆，共 @list.TotalCount 筆資料
            </span>
            <div class="pagination__nav">
                @if (list.HasPreviousPage)
                {
                    <a asp-action="Index" asp-route-keyword="@keyword" asp-route-status="@statusVal"
                       asp-route-dateFrom="@dateFrom" asp-route-dateTo="@dateTo" asp-route-page="1" class="page-btn"
                       aria-label="第一頁" hx-boost="true" hx-target="#finance-results" hx-select="#finance-results"
                       hx-swap="outerHTML" hx-push-url="true">
                        <i class="fa-solid fa-angles-left"></i>
                    </a>
                    <a asp-action="Index" asp-route-keyword="@keyword" asp-route-status="@statusVal"
                       asp-route-dateFrom="@dateFrom" asp-route-dateTo="@dateTo" asp-route-page="@(list.Page - 1)"
                       class="page-btn" aria-label="上一頁" hx-boost="true" hx-target="#finance-results"
                       hx-select="#finance-results" hx-swap="outerHTML" hx-push-url="true">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                }
                else
                {
                    <button class="page-btn" disabled aria-label="第一頁"><i class="fa-solid fa-angles-left"></i></button>
                    <button class="page-btn" disabled aria-label="上一頁"><i class="fa-solid fa-chevron-left"></i></button>
                }

                @{
                    var totalPages = list.TotalPages;
                    var curPage = list.Page;
                    var pages = Enumerable.Range(1, totalPages)
                        .Where(p => p == 1 || p == totalPages || Math.Abs(p - curPage) <= 1)
                        .ToList();
                    int? prev = null;
                }
                @foreach (var p in pages)
                {
                    if (prev.HasValue && p - prev.Value > 1)
                    {
                        <span class="page-ellipsis">…</span>
                    }
                    <a asp-action="Index" asp-route-keyword="@keyword" asp-route-status="@statusVal"
                       asp-route-dateFrom="@dateFrom" asp-route-dateTo="@dateTo" asp-route-page="@p"
                       class="page-btn @(p == curPage ? "active" : "")" hx-boost="true" hx-target="#finance-results"
                       hx-select="#finance-results" hx-swap="outerHTML" hx-push-url="true">@p</a>
                    prev = p;
                }

                @if (list.HasNextPage)
                {
                    <a asp-action="Index" asp-route-keyword="@keyword" asp-route-status="@statusVal"
                       asp-route-dateFrom="@dateFrom" asp-route-dateTo="@dateTo" asp-route-page="@(list.Page + 1)"
                       class="page-btn" aria-label="下一頁" hx-boost="true" hx-target="#finance-results"
                       hx-select="#finance-results" hx-swap="outerHTML" hx-push-url="true">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                    <a asp-action="Index" asp-route-keyword="@keyword" asp-route-status="@statusVal"
                       asp-route-dateFrom="@dateFrom" asp-route-dateTo="@dateTo" asp-route-page="@totalPages" class="page-btn"
                       aria-label="最末頁" hx-boost="true" hx-target="#finance-results" hx-select="#finance-results"
                       hx-swap="outerHTML" hx-push-url="true">
                        <i class="fa-solid fa-angles-right"></i>
                    </a>
                }
                else
                {
                    <button class="page-btn" disabled aria-label="下一頁"><i class="fa-solid fa-chevron-right"></i></button>
                    <button class="page-btn" disabled aria-label="最末頁"><i class="fa-solid fa-angles-right"></i></button>
                }
            </div>
        </div>
    }
</div>

<script>
    (function () {
        const form = document.getElementById('finance-filter-form');
        const statusInput = document.getElementById('finance-status-input');
        const statusSelect = document.getElementById('finance-status-select');

        if (statusSelect) {
            statusSelect.addEventListener('change', function () {
                statusInput.value = this.value;
            });
        }

        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.acc-toggle-btn');
            if (!btn) return;
            var mainRow = btn.closest('.acc-main-row');
            var rowId = mainRow.dataset.row;
            var subRow = document.getElementById('finance-detail-' + rowId);
            if (!subRow) return;

            var isOpen = mainRow.classList.contains('acc-main-row--open');
            if (isOpen) {
                mainRow.classList.remove('acc-main-row--open');
                subRow.classList.add('acc-sub-row--hidden');
                btn.classList.remove('acc-toggle-btn--open');
                btn.innerHTML = '<i class="fa-solid fa-chevron-right"></i>';
            } else {
                mainRow.classList.add('acc-main-row--open');
                subRow.classList.remove('acc-sub-row--hidden');
                btn.classList.add('acc-toggle-btn--open');
                btn.innerHTML = '<i class="fa-solid fa-chevron-down"></i>';
            }
        });
    })();
</script>
