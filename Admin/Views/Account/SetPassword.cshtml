@model Admin.ViewModels.Account.SetPasswordViewModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "設定密碼";
}

@section PageCss {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
}

<div class="wrap">
    <div class="main">
        <div class="wrap_left">
            <div class="login_image"><img src="~/images/login_image.jpg" alt="管理後台登入" /></div>
        </div>
        <div class="wrap_right">
            <div class="login_wrap">
                <div class="page_title">設定管理者後台密碼</div>
                <div class="page_desc">
                    @if (!string.IsNullOrEmpty(Model.Name))
                    {
                        <p>Hi @Model.Name，請設定您的登入密碼。</p>
                        <p>@Model.Email</p>
                    }
                </div>

                <div asp-validation-summary="ModelOnly" class="alert-error"></div>

                <form method="post" asp-action="SetPassword" asp-controller="Account">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Name" />

                    <div class="input_box">
                        <ul>
                            <li>
                                <label class="field_label" asp-for="Password">新密碼</label>
                                <div class="password_wrap">
                                    <input asp-for="Password" id="password-field1" type="password"
                                           autocomplete="new-password" placeholder="請輸入 8 位以上密碼" />
                                    <button type="button" class="pw_toggle_btn" data-target="password-field1"
                                            aria-label="顯示或隱藏密碼">
                                        <i class="fa-regular fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="field_error"></span>
                            </li>
                            <li>
                                <label class="field_label" asp-for="ConfirmPassword">確認密碼</label>
                                <div class="password_wrap">
                                    <input asp-for="ConfirmPassword" id="password-field2" type="password"
                                           autocomplete="new-password" placeholder="請再次輸入密碼" />
                                    <button type="button" class="pw_toggle_btn" data-target="password-field2"
                                            aria-label="顯示或隱藏密碼">
                                        <i class="fa-regular fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="field_error"></span>
                            </li>
                            <li>
                                <div class="btn login_btn">
                                    <button type="submit">完成設定</button>
                                </div>
                            </li>
                        </ul>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
