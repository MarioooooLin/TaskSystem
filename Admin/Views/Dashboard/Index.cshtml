@model Admin.ViewModels.Dashboard.DashboardIndexViewModel
@using Domain.Enums
@{
    ViewData["Title"] = "營運總覽";
    var kpi = Model.Data.Kpi;
    var alerts = Model.Data.Alerts;
    var pendingKols = Model.Data.PendingKolReviews;
    var disputes = Model.Data.RecentDisputes;

    var categoryNames = new Dictionary<short, string>
    {
        [1] = "旅遊",
        [2] = "旅行",
        [3] = "時尚",
        [4] = "美妝",
        [5] = "居家生活",
        [6] = "親子",
        [7] = "寵物",
        [8] = "遊戲",
        [9] = "音樂",
        [10] = "影視",
        [11] = "藝術",
        [12] = "書籍",
        [13] = "科技",
        [14] = "財經",
        [15] = "教育",
        [16] = "職場",
        [17] = "健康",
        [18] = "健身",
        [19] = "運動",
        [20] = "飲食",
        [21] = "養生",
        [22] = "公益",
        [23] = "環保",
        [24] = "政治",
        [25] = "文化",
        [26] = "跨界"
    };

    var platformNames = new Dictionary<short, string>
    {
        [1] = "X",
        [2] = "Instagram",
        [3] = "Facebook",
        [4] = "YouTube",
        [5] = "Blog",
        [6] = "小紅書",
        [7] = "TikTok",
        [8] = "中國抖音",
        [9] = "Threads",
        [10] = "Snapchat",
        [11] = "WeChat"
    };
}

<link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />

<!-- ===== PAGE HEADER ===== -->
<div class="page-header">
    <div class="page-header__left">
        <nav class="adm-breadcrumb">首頁 &rsaquo; 營運總覽</nav>
        <h1 class="page-title">營運總覽</h1>
        <p class="page-subtitle">查看今日待辦、異常事件與平台營運狀態 <span id="todayDate"></span></p>
    </div>
    <button class="btn-primary" hx-get="@Url.Action("Index", "Dashboard")" hx-target="#main-content" hx-push-url="true">
        <i class="fa-solid fa-rotate-right"></i> 重新整理
    </button>
</div>

<!-- ===== KPI STATS ===== -->
<div class="content-card adm-kpi-row">
    <div class="adm-kpi-item">
        <span class="adm-kpi-label">啟用業者數</span>
        <strong class="adm-kpi-value">@kpi.ActiveMerchantCount.ToString("N0")</strong>
    </div>
    <div class="adm-kpi-item">
        <span class="adm-kpi-label">啟用KOL數</span>
        <strong class="adm-kpi-value">@kpi.ActiveKolCount.ToString("N0")</strong>
    </div>
    <div class="adm-kpi-item">
        <span class="adm-kpi-label">進行中案件</span>
        <strong class="adm-kpi-value">@kpi.InProgressCaseCount.ToString("N0")</strong>
    </div>
    <div class="adm-kpi-item">
        <span class="adm-kpi-label">異議處理中</span>
        <strong class="adm-kpi-value adm-kpi-value--alert">@kpi.DisputeCount.ToString("N0")</strong>
    </div>
    <div class="adm-kpi-item adm-kpi-item--last">
        <span class="adm-kpi-label">待匯款金額</span>
        <strong class="adm-kpi-value">NT$@((kpi.PendingPayoutAmount / 1000m).ToString("0"))K</strong>
    </div>
</div>

<!-- ===== DASHBOARD LAYOUT ===== -->
<div class="adm-layout">

    <!-- LEFT: 主欄 -->
    <div class="adm-col-main">

        <!-- KOL 審核待辦 -->
        <div class="content-card">
            <div class="adm-section-hd">
                <h2 class="section-title">
                    <i class="fa-solid fa-user-check"></i> KOL 審核待辦
                </h2>
                <a asp-action="ReviewList" asp-controller="KolManagement"
                   class="adm-section-link"
                   hx-get="@Url.Action("ReviewList", "KolManagement")"
                   hx-target="#main-content"
                   hx-push-url="true">
                    查看全部KOL待審 <i class="fa-solid fa-chevron-right"></i>
                </a>
            </div>
            <div class="table-section">
                <table class="data-table adm-kol-table">
                    <thead>
                        <tr>
                            <th>KOL名稱</th>
                            <th>KOL類型</th>
                            <th>主要平台</th>
                            <th>送審時間</th>
                            <th>狀態</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kol in pendingKols)
                        {
                            var avatarChar = kol.DisplayName.Length > 0 ? kol.DisplayName[0].ToString() : "?";
                            var catText = string.Join(" / ", kol.Categories.Take(2).Select(c =>
                                categoryNames.TryGetValue(c, out var n) ? n : c.ToString()));
                            var platformText = kol.Platforms.Count > 0
                                ? (platformNames.TryGetValue(kol.Platforms[0], out var pn) ? pn : kol.Platforms[0].ToString())
                                : "—";
                            var (pillCss, pillText) = (kol.VerificationStatus, kol.IsResubmit) switch
                            {
                                (VerificationStatus.Pending, true) => ("adm-badge--review", "重送審核"),
                                (VerificationStatus.Pending, _) => ("adm-badge--review", "待審核"),
                                _ => ("adm-badge--review", "待審核")
                            };

                            <tr>
                                <td>
                                    <div class="adm-kol-name">
                                        <span class="adm-kol-avatar" style="background:#4b8ab7;">@avatarChar</span>
                                        @kol.DisplayName
                                    </div>
                                </td>
                                <td>@(string.IsNullOrEmpty(catText) ? "—" : catText)</td>
                                <td>@platformText</td>
                                <td>@kol.SubmittedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td><span class="adm-badge @pillCss">@pillText</span></td>
                                <td><a asp-action="ReviewDetail" asp-controller="KolManagement" asp-route-id="@kol.KolId"
                                           class="action-link"
                                           hx-get="@Url.Action("ReviewDetail", "KolManagement", new { id = kol.KolId })"
                                           hx-target="#main-content"
                                           hx-push-url="true">檢視明細</a></td>
                                </tr>
                            }
                            @if (!pendingKols.Any())
                            {
                                <tr>
                                    <td colspan="6" class="bd-empty-hint">目前無待審核 KOL。</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 異常與異議處理 -->
            <div class="content-card">
                <div class="adm-section-hd">
                    <h2 class="section-title">
                        <i class="fa-solid fa-triangle-exclamation"></i> 異常與異議處理
                    </h2>
                    <a href="#" class="adm-section-link">查看全部異常 <i class="fa-solid fa-chevron-right"></i></a>
                </div>
                <div class="table-section">
                    <table class="data-table adm-dispute-table">
                        <thead>
                            <tr>
                                <th>異議編號</th>
                                <th>案件名稱</th>
                                <th>業者</th>
                                <th>異議類型</th>
                                <th>狀態</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dispute in disputes)
                            {
                                var (pillCss, pillText) = dispute.Status switch
                                {
                                    DisputeStatus.Open => ("adm-badge--processing", "待處理"),
                                    DisputeStatus.UnderReview => ("adm-badge--processing", "處理中"),
                                    _ => ("adm-badge--processing", "處理中")
                                };

                                <tr>
                                    <td>@dispute.DisputeNo</td>
                                    <td>@dispute.CaseTitle</td>
                                    <td>@dispute.MerchantName</td>
                                    <td>@dispute.DisputeType</td>
                                    <td><span class="adm-badge @pillCss">@pillText</span></td>
                                    <td><a href="#" class="action-link">介入處理</a></td>
                                </tr>
                            }
                            @if (!disputes.Any())
                            {
                                <tr>
                                    <td colspan="6" class="bd-empty-hint">目前無處理中異議。</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div><!-- /.adm-col-main -->

        <!-- RIGHT: 側欄 -->
        <aside class="adm-col-side">
            <div class="content-card">
                <h2 class="section-title">時效異常監控</h2>
                <div class="adm-alert-list">
                    <div class="adm-alert-item adm-alert-item--danger">
                        <i class="fa-solid fa-triangle-exclamation adm-alert-icon"></i>
                        <div class="adm-alert-body">
                            <span class="adm-alert-name">已逾期案件</span>
                            <strong class="adm-alert-count">@alerts.OverdueCaseCount.ToString("N0")件</strong>
                        </div>
                    </div>
                    <div class="adm-alert-item">
                        <i class="fa-regular fa-clock adm-alert-icon"></i>
                        <div class="adm-alert-body">
                            <span class="adm-alert-name">驗收逾期</span>
                            <strong class="adm-alert-count">@alerts.ReviewOverdueCount.ToString("N0")件</strong>
                        </div>
                    </div>
                    <div class="adm-alert-item">
                        <i class="fa-solid fa-rotate adm-alert-icon"></i>
                        <div class="adm-alert-body">
                            <span class="adm-alert-name">導購同步異常</span>
                            <strong class="adm-alert-count">@alerts.AffiliateSyncErrorCount.ToString("N0")件</strong>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

    </div><!-- /.adm-layout -->

    @section Scripts {
        <script>
            const d = new Date();
            const pad = n => String(n).padStart(2, '0');
            document.getElementById('todayDate').textContent =
                d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
        </script>
    }
