<?xml version="1.0" encoding="UTF-8" standalone="yes"?><worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main"><sheetViews><sheetView workbookViewId="0"><pane ySplit="1" topLeftCell="A2" activePane="bottomLeft" state="frozen"/></sheetView></sheetViews><sheetFormatPr defaultRowHeight="18"/><sheetData><row r="1"><c r="A1" t="inlineStr" s="1"><is><t>模組</t></is></c><c r="B1" t="inlineStr" s="1"><is><t>資料表</t></is></c><c r="C1" t="inlineStr" s="1"><is><t>用途</t></is></c><c r="D1" t="inlineStr" s="1"><is><t>重點</t></is></c></row><row r="2"><c r="A2" t="inlineStr"><is><t>帳號與身份</t></is></c><c r="B2" t="inlineStr"><is><t>users, vendor_profiles, kol_profiles</t></is></c><c r="C2" t="inlineStr"><is><t>三種角色 admin / 業者 / KOL，Admin 審核業者與 KOL</t></is></c><c r="D2" t="inlineStr"><is><t>業者與 KOL 用 profile 拆開，方便後續補公司與創作者資料</t></is></c></row><row r="3"><c r="A3" t="inlineStr"><is><t>系統參數</t></is></c><c r="B3" t="inlineStr"><is><t>system_settings, system_setting_logs</t></is></c><c r="C3" t="inlineStr"><is><t>Admin 後台設定案件費率、門檻、撥款規則</t></is></c><c r="D3" t="inlineStr"><is><t>設定只影響未來案件，舊案件靠 snapshot 保留</t></is></c></row><row r="4"><c r="A4" t="inlineStr"><is><t>業者額度</t></is></c><c r="B4" t="inlineStr"><is><t>vendor_wallets, vendor_wallet_transactions</t></is></c><c r="C4" t="inlineStr"><is><t>線下匯款入帳、發布案件時凍結額度、結案釋放或結算</t></is></c><c r="D4" t="inlineStr"><is><t>發布即凍結，體驗項目不估值</t></is></c></row><row r="5"><c r="A5" t="inlineStr"><is><t>案件主體</t></is></c><c r="B5" t="inlineStr"><is><t>tasks, task_budget_snapshots</t></is></c><c r="C5" t="inlineStr"><is><t>業者發布合作案件，KOL 報名接任務</t></is></c><c r="D5" t="inlineStr"><is><t>案件狀態與招募狀態分開，支援執行中仍可招募</t></is></c></row><row r="6"><c r="A6" t="inlineStr"><is><t>條件與附件</t></is></c><c r="B6" t="inlineStr"><is><t>task_platforms, task_categories, task_languages, task_barter_items, task_attachments</t></is></c><c r="C6" t="inlineStr"><is><t>KOL 條件、多平台交付、體驗項目、附件</t></is></c><c r="D6" t="inlineStr"><is><t>KOL 條件為提示，不阻擋報名</t></is></c></row><row r="7"><c r="A7" t="inlineStr"><is><t>報名與執行</t></is></c><c r="B7" t="inlineStr"><is><t>task_applications, task_assignments</t></is></c><c r="C7" t="inlineStr"><is><t>KOL 報名後由業者審核，可錄取多位 KOL</t></is></c><c r="D7" t="inlineStr"><is><t>自動執行門檻看報名人數</t></is></c></row><row r="8"><c r="A8" t="inlineStr"><is><t>交付與驗收</t></is></c><c r="B8" t="inlineStr"><is><t>task_deliverables, task_deliverable_items</t></is></c><c r="C8" t="inlineStr"><is><t>KOL 提交成果，業者驗收才算完成</t></is></c><c r="D8" t="inlineStr"><is><t>每位 KOL 的執行狀態獨立</t></is></c></row><row r="9"><c r="A9" t="inlineStr"><is><t>評分</t></is></c><c r="B9" t="inlineStr"><is><t>task_reviews, task_review_scores</t></is></c><c r="C9" t="inlineStr"><is><t>結案後 KOL 與業者互評，雙方評分項目不同</t></is></c><c r="D9" t="inlineStr"><is><t>先暫定驗收後完成，評分可補填</t></is></c></row><row r="10"><c r="A10" t="inlineStr"><is><t>爭議</t></is></c><c r="B10" t="inlineStr"><is><t>task_disputes, task_dispute_messages, task_dispute_attachments</t></is></c><c r="C10" t="inlineStr"><is><t>申訴與平台介入處理</t></is></c><c r="D10" t="inlineStr"><is><t>爭議中的 KOL 金額可先 hold，不影響其他 KOL</t></is></c></row><row r="11"><c r="A11" t="inlineStr"><is><t>紀錄</t></is></c><c r="B11" t="inlineStr"><is><t>task_activity_logs</t></is></c><c r="C11" t="inlineStr"><is><t>誰改了什麼、狀態異動、關鍵操作</t></is></c><c r="D11" t="inlineStr"><is><t>before_data / after_data 用 JSON</t></is></c></row></sheetData><cols><col min="1" max="1" width="28" customWidth="1"/><col min="2" max="2" width="28" customWidth="1"/><col min="3" max="3" width="28" customWidth="1"/><col min="4" max="4" width="28" customWidth="1"/></cols></worksheet>