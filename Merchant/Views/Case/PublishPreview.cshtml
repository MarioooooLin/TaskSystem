@using Domain.Enums
@using Merchant.Models
@model Merchant.ViewModels.Cases.PublishPreviewViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "送審確認";

    string FormatBytes(long bytes)
    {
        if (bytes >= 1024 * 1024) return $"{bytes / (1024.0 * 1024.0):F1} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes} B";
    }

    string GetFileIcon(string mimeType)
    {
        if (mimeType.StartsWith("image/")) return "fa-file-image";
        if (mimeType.StartsWith("video/")) return "fa-file-video";
        if (mimeType.Contains("pdf")) return "fa-file-pdf";
        if (mimeType.Contains("word") || mimeType.Contains("document")) return "fa-file-word";
        if (mimeType.Contains("zip") || mimeType.Contains("compressed")) return "fa-file-zipper";
        return "fa-file";
    }
}

@section PageCss {
    <link rel="stylesheet" href="~/css/publish.css" asp-append-version="true" />
}

<div class="content-card pub-card">

    <!-- BREADCRUMB -->
    <nav class="pub-breadcrumb">
        <a asp-action="Index">案件管理</a>
        <i class="fa-solid fa-chevron-right"></i>
        <a asp-action="Edit" asp-route-id="@Model.CaseId">新增案件</a>
        <i class="fa-solid fa-chevron-right"></i>
        <span>送審確認</span>
    </nav>

    <!-- PAGE TITLE -->
    <h1 class="pub-page-title">發佈案件確認</h1>

    <!-- WARNING ALERT -->
    <div class="pub-alert">
        <div class="pub-alert__icon">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <div class="pub-alert__body">
            <p class="pub-alert__title">重要確認事項</p>
            <p class="pub-alert__desc">發佈案件之後，系統將會依據您設定的預算金額進行資金融定。若需更動請回草稿後重試。</p>
        </div>
    </div>

    <form asp-action="Publish" method="post" id="publish-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CaseId" />
        <input type="hidden" asp-for="IdempotencyKey" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- MAIN LAYOUT: 左側摘要 + 右側預算 -->
        <div class="pub-layout">

            <!-- ===== LEFT: 摘要區 ===== -->
            <div class="pub-body">

                <!-- 案件摘要 -->
                <section class="pub-section">
                    <div class="pub-section__header">
                        <div class="pub-section__title">
                            <i class="fa-regular fa-file-lines"></i> 案件摘要
                        </div>
                        <span class="pub-section__badge">不可編輯</span>
                    </div>
                    <div class="pub-info-grid">
                        <div class="pub-info-item">
                            <span class="pub-info-label">案件名稱</span>
                            <span class="pub-info-value">@Model.Title</span>
                        </div>
                        <div class="pub-info-item">
                            <span class="pub-info-label">地區</span>
                            <span class="pub-info-value">@(Model.City) @(Model.Address)</span>
                        </div>
                        <div class="pub-info-item">
                            <span class="pub-info-label">招募人數</span>
                            <span class="pub-info-value">@Model.WantedKolCount 位</span>
                        </div>
                        <div class="pub-info-item">
                            <span class="pub-info-label">執行區間</span>
                            <span class="pub-info-value">@Model.ApplicationDeadline.ToString("yyyy-MM-dd") ～
                                @Model.SubmissionDeadline.ToString("yyyy-MM-dd")</span>
                            </div>
                        </div>
                    </section>

                    <!-- 合作條件摘要 + 平台與交付摘要 -->
                    <div class="pub-two-col">

                        <!-- 合作條件摘要 -->
                        <section class="pub-section">
                            <div class="pub-section__header">
                                <div class="pub-section__title">
                                    <i class="fa-regular fa-handshake"></i> 合作條件摘要
                                </div>
                            </div>
                            <table class="pub-kv-table">
                                <tr>
                                    <td class="pub-kv-label">現金酬勞</td>
                                    <td class="pub-kv-value">NT$ @Model.RewardAmountPerKol.ToString("N0") / 人</td>
                                </tr>
                                <tr>
                                    <td class="pub-kv-label">贈驗項目</td>
                                    <td class="pub-kv-value">
                                        @(Model.BarterItems.Count > 0
                                            ? string.Join(", ", Model.BarterItems.Select(b => b.Name))
                                            : "無")
                                    </td>
                                </tr>
                                <tr>
                                    <td class="pub-kv-label">導購分潤</td>
                                    <td class="pub-kv-value">
                                        @(Model.HasCommission && Model.CommissionRate.HasValue
                                            ? $"轉換訂單 {Model.CommissionRate.Value:F0}% 抽成"
                                            : "無")
                                    </td>
                                </tr>
                            </table>
                        </section>

                        <!-- 平台與交付摘要 -->
                        <section class="pub-section">
                            <div class="pub-section__header">
                                <div class="pub-section__title">
                                    <i class="fa-regular fa-paper-plane"></i> 平台與交付摘要
                                </div>
                            </div>
                            <div class="pub-platform-tags">
                                @foreach (var platform in Model.Platforms)
                                {
                                    if (CaseEditLookups.PlatformNames.TryGetValue((SocialPlatform)platform, out var name))
                                    {
                                        <span class="pub-platform-tag">@name</span>
                                    }
                                }
                            </div>
                            <p class="pub-kv-label" style="margin-top:1.2rem; margin-bottom:.4rem;">交付需求：</p>
                            <p class="pub-delivery-text">@(string.IsNullOrWhiteSpace(Model.DeliverableDescription) ? "—" :
                                                                                            Model.DeliverableDescription)</p>
                            </section>

                        </div><!-- /.pub-two-col -->

                        <!-- 附件摘要 -->
                        <section class="pub-section">
                            <div class="pub-section__header">
                                <div class="pub-section__title">
                                    <i class="fa-solid fa-paperclip"></i> 附件摘要
                                </div>
                            </div>
                            <div class="pub-file-list">
                                @if (Model.Attachments.Count == 0)
                                {
                                    <p class="pub-hint">無附件</p>
                                }
                                else
                                {
                                    @foreach (var file in Model.Attachments)
                                    {
                                        <div class="pub-file-item">
                                            <i class="fa-regular @GetFileIcon(file.MimeType) pub-file-icon"></i>
                                            <span class="pub-file-name">@file.FileName</span>
                                            <span class="pub-file-size">@FormatBytes(file.FileSize)</span>
                                        </div>
                                    }
                                }
                            </div>
                        </section>

                        <!-- 最後確認 -->
                        <section class="pub-section pub-section--confirm">
                            <div class="pub-section__header">
                                <div class="pub-section__title">最後確認</div>
                            </div>
                            <div class="pub-check-list">
                                <label class="pub-check-item">
                                    <input type="checkbox" asp-for="Confirmed" id="confirmContent">
                                    <span class="pub-checkmark"></span>
                                    我確認案件內容正確且無誤
                                </label>
                                <label class="pub-check-item">
                                    <input type="checkbox" id="confirmBudget">
                                    <span class="pub-checkmark"></span>
                                    我了解預算 NT$ @Model.EstimatedFrozenAmount.ToString("N0") 將從餘額中鎖定
                                </label>
                            </div>
                            <span asp-validation-for="Confirmed" class="text-danger"></span>
                        </section>

                    </div><!-- /.pub-body -->

                    <!-- ===== RIGHT: 預算鎖定摘要 ===== -->
                    <aside class="pub-budget">
                        <h3 class="pub-budget__title">預算預估</h3>
                        <div class="pub-budget__rows">
                            <div class="pub-budget__row">
                                <span>單人報酬</span>
                                <span>NT$ @Model.RewardAmountPerKol.ToString("N0")</span>
                            </div>
                            <div class="pub-budget__row">
                                <span>徵求人數</span>
                                <span>× @Model.WantedKolCount</span>
                            </div>
                            <div class="pub-budget__divider"></div>
                            <div class="pub-budget__row">
                                <span>小計</span>
                                <span>NT$ @Model.RewardSubtotal.ToString("N0")</span>
                            </div>
                            <div class="pub-budget__row">
                                <span>開案費</span>
                                <span>NT$ @Model.CaseOpeningFee.ToString("N0")</span>
                            </div>
                            <div class="pub-budget__row pub-budget__row--red">
                                <span>折扣</span>
                                <span>NT$ @Model.DiscountAmount.ToString("N0")</span>
                            </div>
                            <div class="pub-budget__row">
                                <span>平台服務費</span>
                                <span>NT$ @Model.PlatformServiceFee.ToString("N0")</span>
                            </div>
                        </div>
                        <div class="pub-budget__divider"></div>
                        <div class="pub-budget__total">
                            <span>預計鎖定總額</span>
                            <span class="pub-budget__total-amount">NT$ @Model.EstimatedFrozenAmount.ToString("N0")</span>
                        </div>
                        @if (!Model.HasEnoughBalance)
                        {
                            <div class="ac-budget__warn" style="margin-top:1.2rem;">
                                <i class="fa-solid fa-circle-exclamation"></i>
                                <span>錢包可用餘額不足，請先儲值後再發布。</span>
                            </div>
                        }
                    </aside>

                </div><!-- /.pub-layout -->
            </form>
        </div><!-- /.content-card -->

        <!-- BOTTOM STICKY ACTION BAR -->
        <div class="pub-action-bar" id="pubActionBar">
            <a asp-action="Edit" asp-route-id="@Model.CaseId" class="pub-action-bar__back">
                <i class="fa-solid fa-arrow-left"></i> 返回編輯
            </a>
            <div class="pub-action-bar__right">
                <div class="pub-action-bar__amount">
                    <span class="pub-action-bar__amount-label">鎖定總額</span>
                    <span class="pub-action-bar__amount-value">NT$ @Model.EstimatedFrozenAmount.ToString("N0")</span>
                </div>
                <button type="submit" form="publish-form" class="pub-action-bar__submit" id="pubSubmitBtn"
                        data-has-enough-balance="@(Model.HasEnoughBalance ? "true" : "false")" disabled>
                    確認發佈
                </button>
            </div>
        </div>

        @section Scripts {
            <partial name="_ValidationScriptsPartial" />
            <script>
                (function () {
                    var $confirmContent = $('#confirmContent');
                    var $confirmBudget = $('#confirmBudget');
                    var $submitBtn = $('#pubSubmitBtn');

                    function updateSubmitButton() {
                        var hasEnoughBalance = $submitBtn.data('has-enough-balance') === 'true';
                        var allChecked = $confirmContent.is(':checked') && $confirmBudget.is(':checked');
                        $submitBtn.prop('disabled', !(allChecked && hasEnoughBalance));
                    }

                    $confirmContent.on('change', updateSubmitButton);
                    $confirmBudget.on('change', updateSubmitButton);
                    updateSubmitButton();
                })();
            </script>
        }
