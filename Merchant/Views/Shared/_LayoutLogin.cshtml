<!DOCTYPE html>
<html lang="zh-TW">

<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
    <title>@ViewData["Title"] - 任務系統業者管理後台</title>
    <link rel="shortcut icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/reset.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/w3.css" asp-append-version="true" />
    @await RenderSectionAsync("PageCss", required: false)
</head>

<body>
    <div class="md_transition"></div>

    @RenderBody()

    <footer>
        <div class="copyright">
            此系統已通過 SSL安全金融交易認證
            <br class="br-break" />
            系統開發單位：<a href="https://www.taiwantravelmap.com/" target="_blank" rel="noopener noreferrer">台灣旅圖資訊</a>
            <br class="br-break" />
            2026 Taiwantravelmap Co Ltd. All Rights Reserved.
        </div>
    </footer>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js" crossorigin="anonymous"></script>
    <script src="~/js/pw-toggle.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
