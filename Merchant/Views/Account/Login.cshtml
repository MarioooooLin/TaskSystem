@model Merchant.ViewModels.Account.LoginViewModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "登入";
}

@section PageCss {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
}

<div class="wrap">
    <div class="main">
        <div class="wrap_left">
            <div class="login_image"><img src="~/images/login_image.jpg" alt="業者管理後台登入" /></div>
        </div>
        <div class="wrap_right">
            <div class="login_wrap">
                <div class="page_title">任務系統業者管理後台</div>
                <div class="page_desc">登入您的業者管理後台以管理案件與成效。</div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-error">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p>@error.ErrorMessage</p>
                        }
                    </div>
                }

                <form method="post" asp-action="Login" asp-controller="Account">
                    @Html.AntiForgeryToken()

                    <div class="input_box">
                        <ul>
                            <li>
                                <label class="field_label" asp-for="TaxId">公司統一編號</label>
                                <input asp-for="TaxId" type="text" placeholder="請輸入8位數統一編號" inputmode="numeric"
                                       autocomplete="username" />
                                <span asp-validation-for="TaxId" class="field_error"></span>
                            </li>
                            <li>
                                <label class="field_label" asp-for="Email">帳號 / 電子郵件</label>
                                <input asp-for="Email" type="email" placeholder="example@company.com"
                                       autocomplete="email" />
                                <span asp-validation-for="Email" class="field_error"></span>
                            </li>
                            <li>
                                <label class="field_label" asp-for="Password">密碼</label>
                                <div class="password_wrap">
                                    <input asp-for="Password" id="password-field1" type="password"
                                           autocomplete="current-password" />
                                    <button type="button" class="pw_toggle_btn" data-target="password-field1"
                                            aria-label="顯示或隱藏密碼">
                                        <i class="fa-regular fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="field_error"></span>
                            </li>
                            <li>
                                <div class="remember_row">
                                    <label class="remember_me">
                                        <input asp-for="RememberMe" type="checkbox" />
                                        <span class="prm-checkmark"></span> 記住我
                                    </label>
                                    <a href="#" class="forgot_pw_link">忘記密碼？</a>
                                </div>
                            </li>
                            <li>
                                <div class="btn login_btn">
                                    <button type="submit">立即登入</button>
                                </div>
                            </li>
                        </ul>
                    </div>
                </form>

                <div class="register_link">尚未擁有帳號？<a href="#">立即申請</a></div>
            </div>
        </div>
    </div>
</div>
